import re
import heapq
from nltk.corpus import stopwords
from nltk.tokenize import word_tokenize, sent_tokenize
text = """
Artificial Intelligence is becoming one of the most important technologies in the world.
It is used in healthcare, banking, education, transportation, and cybersecurity.
AI helps doctors detect diseases early and improves medical treatments.
Many companies use AI chatbots to provide customer support.
Machine learning systems analyze large amounts of data quickly and accurately.

Although AI provides many advantages, there are also some challenges.
Privacy issues, ethical concerns, and job replacement due to automation are important problems.
Governments are creating rules and regulations for responsible AI usage.
"""
clean_text = re.sub(r'\s+', ' ', text)
sentences = sent_tokenize(text)
stop_words = set(stopwords.words('english'))
word_frequency = {}
words = word_tokenize(clean_text)
for word in words:
    word = word.lower()
    if word.isalnum() and word not in stop_words:
        if word not in word_frequency:
            word_frequency[word] = 1
        else:
            word_frequency[word] += 1
max_frequency = max(word_frequency.values())
for word in word_frequency.keys():

    word_frequency[word] = (word_frequency[word] / max_frequency)
sentence_scores = {}
for sentence in sentences:
    for word in word_tokenize(sentence.lower()):
        if word in word_frequency:
            if len(sentence.split(' ')) < 30:
                if sentence not in sentence_scores:
                    sentence_scores[sentence] = ( word_frequency[word])

                else:
                    sentence_scores[sentence] += (word_frequency[word])
summary_sentences = heapq.nlargest(3,sentence_scores,key=sentence_scores.get)
summary = ' '.join(summary_sentences)
print("----> ORIGINAL TEXT :")
print(text)
print("----> SUMMARY : ")
print(summary)
